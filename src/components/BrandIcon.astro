---
/**
 * Brand icon — eyedropper with VIBGYOR rainbow gradient.
 *
 * Used in Nav, Footer, hero, favicon (variant). Single source of truth for
 * the brand mark. Gradient is theme-agnostic — works on both light and dark.
 *
 * Props:
 *   - size: pixel size (default 24)
 *   - class: extra classes for the <svg>
 */
interface Props {
  size?: number;
  class?: string;
  ariaLabel?: string;
}
const { size = 24, class: extraClass = "", ariaLabel = "ColorTrail icon" } = Astro.props;
---
<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  class={extraClass}
  fill="none"
  stroke="url(#colortrail-gradient)"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-label={ariaLabel}
  role="img"
>
  <defs>
    {/* VIBGYOR — softened slightly for both-theme legibility */}
    <linearGradient id="colortrail-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#ff3d3d" /> {/* Red */}
      <stop offset="16%" stop-color="#ff8a3d" /> {/* Orange */}
      <stop offset="33%" stop-color="#ffd23d" /> {/* Yellow */}
      <stop offset="50%" stop-color="#3ddc84" /> {/* Green */}
      <stop offset="66%" stop-color="#3da5ff" /> {/* Blue */}
      <stop offset="83%" stop-color="#7a5af8" /> {/* Indigo */}
      <stop offset="100%" stop-color="#c450ff" /> {/* Violet */}
    </linearGradient>
  </defs>
  <path d="m2 22 1-1h3l9-9" />
  <path d="M3 21v-3l9-9" />
  <path d="m15 6 3.4-3.4a2.121 2.121 0 1 1 3 3L18 9l.4.4a2.121 2.121 0 1 1-3 3l-3.8-3.8a2.121 2.121 0 1 1 3-3l.4.4Z" />
</svg>
