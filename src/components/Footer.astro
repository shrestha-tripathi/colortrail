---
import { site, b } from "../site.config";
import BrandIcon from "./BrandIcon.astro";
const year = new Date().getFullYear();
---

<footer class="mt-24" style="box-shadow: inset 0 1px 0 var(--color-border);">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-10 grid gap-8 sm:grid-cols-2 items-start">
    <div>
      <div class="flex items-center gap-2 text-[15px] font-semibold text-[var(--color-fg)] mb-3" style="letter-spacing: -0.02em;">
        <BrandIcon size={18} />
        <span>{site.name}</span>
      </div>
      <p class="text-[14px] text-[var(--color-fg-secondary)] leading-relaxed max-w-md">
        100% free, no signup, no tracking — forever. Built in the browser.
        Your colors never leave your device.
      </p>
    </div>

    <nav class="flex flex-wrap gap-x-6 gap-y-3 text-[14px] sm:justify-end">
      <a href={b("/")} class="text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors">Home</a>
      <a href={b("/about")} class="text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors">About</a>
      <a href={b("/privacy")} class="text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors">Privacy</a>
      {site.github && (
        <a href={site.github} target="_blank" rel="noopener" class="text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors">
          GitHub →
        </a>
      )}
    </nav>
  </div>
  <div style="box-shadow: inset 0 1px 0 var(--color-border);">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-4 flex items-center justify-between text-[12px] text-[var(--color-fg-subtle)]">
      <span>© {year} {site.name}</span>
      <span class="font-mono uppercase tracking-wider" style="font-feature-settings: 'tnum' 1;">Built in 🇮🇳</span>
    </div>
  </div>
</footer>
