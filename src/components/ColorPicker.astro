---
/**
 * ColorPicker — the main interactive feature.
 *
 * Two modes:
 *   1. LIVE  — window.EyeDropper API. Instant, magical, requires desktop +
 *              Chromium. Cancels if user switches tabs.
 *   2. SHOT  — getDisplayMedia capture. Universal browser support. Frozen
 *              frame can be picked from leisurely — no tab-switch race.
 *
 * The Screenshot mode is the "huge UX win" — it lets users pick colors
 * from another browser tab, a minimized-then-shown window, a streaming
 * video paused at a specific frame, etc.
 */
import BrandIcon from "./BrandIcon.astro";
---

<section id="picker-root" class="w-full">
  {/* Browser compatibility banner (live mode only) */}
  <div
    id="compat-banner"
    class="hidden mx-auto max-w-2xl mb-8 rounded-md px-4 py-3 text-[14px] leading-relaxed text-[var(--color-fg)]"
    style="background-color: var(--color-warning-bg); box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-warning) 25%, transparent);"
    role="status"
    aria-live="polite"
  >
    <p id="compat-banner-text"></p>
  </div>

  {/* CTA cluster — two buttons */}
  <div class="text-center mb-10">
    <div class="relative inline-block">
      <span class="brand-halo" aria-hidden="true"></span>

      <div class="relative inline-flex flex-col sm:flex-row items-center justify-center gap-3">
        {/* Primary: Live picker (gradient) */}
        <button
          type="button"
          id="pick-btn"
          class="btn-brand inline-flex items-center justify-center gap-2.5 rounded-md px-6 py-3.5 text-[15px]
                 active:scale-[0.98]
                 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0"
          aria-label="Pick a color from your screen using EyeDropper"
        >
          <BrandIcon size={18} class="opacity-90" ariaLabel="" />
          <span id="pick-btn-label">Pick a color</span>
          <kbd class="ml-1 px-1.5 py-0.5 text-[11px] font-mono leading-none rounded text-white" style="background-color: rgba(255,255,255,0.18);">
            P
          </kbd>
        </button>

        {/* Secondary: Screenshot mode */}
        <button
          type="button"
          id="shot-btn"
          class="inline-flex items-center justify-center gap-2.5 rounded-md px-5 py-3 text-[14px] font-medium
                 text-[var(--color-fg)] hover:text-[var(--color-fg)]
                 transition-colors
                 disabled:opacity-50 disabled:cursor-not-allowed"
          style="box-shadow: var(--shadow-ring);"
          aria-label="Pick a color from a screenshot of another window or tab"
        >
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3z"/>
            <circle cx="12" cy="13" r="3"/>
          </svg>
          <span>Pick from screenshot</span>
        </button>
      </div>
    </div>

    <p id="pick-hint" class="mt-5 text-[14px] text-[var(--color-fg-secondary)] max-w-md mx-auto leading-relaxed">
      <span class="font-medium text-[var(--color-fg)]">Pick a color</span> — instant, picks from anywhere on screen (even outside the browser).
      <br />
      <span class="font-medium text-[var(--color-fg)]">Screenshot</span> — when you need to pick from another tab without losing focus.
    </p>
  </div>

  {/* Active color result card */}
  <div
    id="result-card"
    class="hidden mx-auto max-w-2xl rounded-lg overflow-hidden mb-10"
    style="background-color: var(--color-bg); box-shadow: var(--shadow-card);"
  >
    <div class="grid sm:grid-cols-[180px_1fr] items-stretch">
      <div
        id="result-swatch"
        class="min-h-[120px] sm:min-h-[180px] flex items-end justify-start p-4 font-mono text-[12px]"
        style="background-color: #171717;"
      >
        <span id="result-swatch-hex" class="opacity-80 uppercase tracking-wider">#171717</span>
      </div>

      <div class="p-5 sm:p-6 grid gap-3">
        <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3">
          <span class="eyebrow">HEX</span>
          <code id="fmt-hex" class="font-mono text-[15px] text-[var(--color-fg)] truncate" style="font-feature-settings: 'liga' 1;">#171717</code>
          <button type="button" data-copy="hex" class="copy-btn px-2.5 py-1 rounded-md text-[12px] font-medium text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors" style="box-shadow: var(--shadow-ring);" aria-label="Copy HEX">Copy</button>
        </div>
        <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3">
          <span class="eyebrow">RGB</span>
          <code id="fmt-rgb" class="font-mono text-[15px] text-[var(--color-fg)] truncate">rgb(23, 23, 23)</code>
          <button type="button" data-copy="rgb" class="copy-btn px-2.5 py-1 rounded-md text-[12px] font-medium text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors" style="box-shadow: var(--shadow-ring);" aria-label="Copy RGB">Copy</button>
        </div>
        <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3">
          <span class="eyebrow">HSL</span>
          <code id="fmt-hsl" class="font-mono text-[15px] text-[var(--color-fg)] truncate">hsl(0, 0%, 9%)</code>
          <button type="button" data-copy="hsl" class="copy-btn px-2.5 py-1 rounded-md text-[12px] font-medium text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors" style="box-shadow: var(--shadow-ring);" aria-label="Copy HSL">Copy</button>
        </div>
        <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3">
          <span class="eyebrow" title="Perceptually uniform — CSS Color Level 4">OKLCH</span>
          <code id="fmt-oklch" class="font-mono text-[15px] text-[var(--color-fg)] truncate">oklch(22.04% 0.0000 0.0)</code>
          <button type="button" data-copy="oklch" class="copy-btn px-2.5 py-1 rounded-md text-[12px] font-medium text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors" style="box-shadow: var(--shadow-ring);" aria-label="Copy OKLCH">Copy</button>
        </div>
      </div>
    </div>
  </div>

  {/* Palette history strip */}
  <div id="palette-section" class="hidden mx-auto max-w-2xl">
    <div class="flex items-center justify-between mb-4 px-1">
      <h2 class="eyebrow">
        Recent palette
        <span id="palette-count" class="ml-1 text-[var(--color-fg-subtle)]">(0)</span>
      </h2>
      <button
        type="button"
        id="clear-palette"
        class="text-[12px] font-medium text-[var(--color-fg-secondary)] hover:text-[var(--color-error)] transition-colors"
      >
        Clear all
      </button>
    </div>
    <div
      id="palette-grid"
      class="grid grid-cols-8 sm:grid-cols-12 gap-2"
      role="list"
      aria-label="Recent color palette"
    >
    </div>
  </div>

  {/* ===== SCREENSHOT MODE MODAL ===== */}
  <div
    id="shot-modal"
    class="hidden fixed inset-0 z-50 flex items-center justify-center p-2 sm:p-6"
    style="background-color: rgba(0,0,0,0.75); backdrop-filter: blur(4px);"
    role="dialog"
    aria-modal="true"
    aria-labelledby="shot-modal-title"
  >
    <div
      class="relative w-full max-w-6xl max-h-[95vh] rounded-lg overflow-hidden flex flex-col"
      style="background-color: var(--color-bg); box-shadow: var(--shadow-card);"
    >
      {/* Modal header */}
      <header
        class="flex items-center justify-between gap-4 px-4 sm:px-5 py-3 shrink-0"
        style="box-shadow: inset 0 -1px 0 var(--color-border);"
      >
        <div class="flex items-center gap-3 min-w-0">
          <span class="eyebrow">Screenshot picker</span>
          <span
            id="shot-status"
            class="text-[13px] text-[var(--color-fg-secondary)] truncate"
          >
            Select a screen, window, or tab to capture…
          </span>
        </div>
        <button
          type="button"
          id="shot-close"
          class="shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-md text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-colors"
          aria-label="Close screenshot picker"
        >
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </header>

      {/* Canvas + magnifier area */}
      <div
        id="shot-canvas-wrap"
        class="relative flex-1 overflow-auto flex items-center justify-center p-4"
        style="background-color: var(--color-bg-elevated); min-height: 200px;"
      >
        <p id="shot-empty" class="text-[14px] text-[var(--color-fg-secondary)] text-center max-w-md">
          Click <em>Choose what to capture</em> below.
          Your browser will show its picker for screens, windows, or tabs.
        </p>
        <canvas
          id="shot-canvas"
          class="hidden max-w-full max-h-full rounded-md cursor-crosshair"
          style="box-shadow: var(--shadow-ring); image-rendering: pixelated;"
        ></canvas>

        {/* Magnifier loupe (Vercel cards / popovers pattern) */}
        <div
          id="shot-loupe"
          class="hidden absolute pointer-events-none rounded-full"
          style="width: 140px; height: 140px; box-shadow: 0 0 0 2px rgba(0,0,0,0.85), 0 0 0 4px rgba(255,255,255,0.6), 0 10px 30px rgba(0,0,0,0.4); overflow: hidden;"
        >
          <canvas id="shot-loupe-canvas" width="140" height="140"></canvas>
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
            style="width: 10px; height: 10px; box-shadow: 0 0 0 1px #000, inset 0 0 0 1px #fff;"
          ></div>
        </div>
      </div>

      {/* Modal footer */}
      <footer
        class="flex items-center justify-between gap-3 px-4 sm:px-5 py-3 shrink-0"
        style="box-shadow: inset 0 1px 0 var(--color-border);"
      >
        <div class="flex items-center gap-3 min-w-0">
          <span
            id="shot-preview-swatch"
            class="hidden shrink-0 w-7 h-7 rounded-md"
            style="box-shadow: var(--shadow-ring);"
            aria-hidden="true"
          ></span>
          <code
            id="shot-preview-hex"
            class="hidden font-mono text-[14px] text-[var(--color-fg)] tracking-wider"
          >#000000</code>
          <span class="text-[12px] text-[var(--color-fg-subtle)] hidden sm:inline" id="shot-preview-hint">
            Hover to preview · click to lock in
          </span>
        </div>
        <div class="flex items-center gap-2">
          <button
            type="button"
            id="shot-recapture"
            class="hidden inline-flex items-center gap-2 px-3.5 py-2 rounded-md text-[13px] font-medium text-[var(--color-fg)] hover:text-[var(--color-fg)] transition-colors"
            style="box-shadow: var(--shadow-ring);"
          >
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 12a9 9 0 0 1 15.6-6.2L21 8"/>
              <path d="M21 3v5h-5"/>
              <path d="M21 12a9 9 0 0 1-15.6 6.2L3 16"/>
              <path d="M3 21v-5h5"/>
            </svg>
            Recapture
          </button>
          <button
            type="button"
            id="shot-capture"
            class="inline-flex items-center gap-2 px-3.5 py-2 rounded-md text-[13px] font-medium bg-[var(--color-fg)] text-[var(--color-bg)] hover:opacity-90 transition-opacity"
          >
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3z"/>
              <circle cx="12" cy="13" r="3"/>
            </svg>
            Choose what to capture
          </button>
        </div>
      </footer>
    </div>
  </div>

  {/* ===== PRE-CAPTURE HINT MODAL (heads-up about focus switch) ===== */}
  <div
    id="hint-modal"
    class="hidden fixed inset-0 z-[55] flex items-center justify-center p-4"
    style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(3px);"
    role="dialog"
    aria-modal="true"
    aria-labelledby="hint-modal-title"
    aria-describedby="hint-modal-body"
  >
    <div
      class="relative w-full max-w-md rounded-lg overflow-hidden"
      style="background-color: var(--color-bg); box-shadow: var(--shadow-card);"
    >
      <div class="p-6">
        <div class="flex items-start gap-3 mb-4">
          <div
            class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-md"
            style="background-color: var(--color-badge-bg); color: var(--color-badge-fg);"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 9v4"/>
              <path d="M12 17h.01"/>
              <circle cx="12" cy="12" r="10"/>
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <h3
              id="hint-modal-title"
              class="text-[17px] font-semibold text-[var(--color-fg)] mb-1"
              style="letter-spacing: -0.015em;"
            >
              One quick heads-up
            </h3>
            <p class="text-[11px] text-[var(--color-fg-secondary)] uppercase tracking-wider font-mono font-medium">
              How screen capture works
            </p>
          </div>
        </div>

        {/* Mini 3-step visual */}
        <ol class="grid grid-cols-3 gap-2 mb-5" aria-hidden="true">
          {[
            { emoji: "📤", label: "Pick window" },
            { emoji: "👀", label: "Browser focuses it" },
            { emoji: "↩️", label: "Come back here" },
          ].map((step, i) => (
            <li
              class="rounded-md p-3 text-center"
              style="background-color: var(--color-bg-elevated); box-shadow: var(--shadow-ring);"
            >
              <div class="text-[22px] leading-none mb-1.5">{step.emoji}</div>
              <div class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-fg-subtle)] mb-0.5">
                Step {String(i + 1).padStart(2, "0")}
              </div>
              <div class="text-[11px] font-medium text-[var(--color-fg)] leading-tight">
                {step.label}
              </div>
            </li>
          ))}
        </ol>

        <p
          id="hint-modal-body"
          class="text-[14px] text-[var(--color-fg-secondary)] leading-relaxed mb-4"
        >
          After you click <strong class="text-[var(--color-fg)]">Continue</strong>, your
          browser will switch focus to the window you're sharing.
          <strong class="text-[var(--color-fg)]"> Press <kbd id="hint-shortcut-kbd" class="inline-block px-2 py-1 mx-0.5 rounded-md font-mono text-[12px] font-semibold text-[var(--color-fg)]" style="background-color: var(--color-surface); box-shadow: var(--shadow-ring), 0 1px 0 rgba(0,0,0,0.05);">Alt + Tab</kbd></strong>
          to come back here — your captured frame will be waiting.
        </p>

        <label class="flex items-center gap-2 mb-5 cursor-pointer select-none group">
          <input
            type="checkbox"
            id="hint-dontshow"
            class="w-4 h-4 rounded cursor-pointer"
            style="accent-color: var(--color-fg);"
          />
          <span class="text-[13px] text-[var(--color-fg-secondary)] group-hover:text-[var(--color-fg)] transition-colors">
            Don't show this again
          </span>
        </label>

        <div class="flex items-center justify-end gap-2">
          <button
            type="button"
            id="hint-cancel"
            class="px-4 py-2 rounded-md text-[13px] font-medium text-[var(--color-fg-secondary)] hover:text-[var(--color-fg)] transition-all"
            style="background-color: var(--color-surface-strong); box-shadow: var(--shadow-ring);"
          >
            Cancel
          </button>
          <button
            type="button"
            id="hint-continue"
            class="inline-flex items-center gap-2 px-3.5 py-2 rounded-md text-[13px] font-medium bg-[var(--color-fg)] text-[var(--color-bg)] hover:opacity-90 transition-opacity"
            autofocus
          >
            Continue
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  {/* Toast */}
  <div
    id="toast"
    class="hidden fixed left-1/2 bottom-8 -translate-x-1/2 z-[60]
           px-4 py-2.5 rounded-md text-[13px] font-medium font-mono
           bg-[var(--color-fg)] text-[var(--color-bg)]"
    style="animation: toast-in 0.2s ease-out; box-shadow: 0 8px 24px rgba(0,0,0,0.15);"
    role="status"
    aria-live="polite"
  ></div>
</section>

<script src="./ColorPicker.script.ts"></script>
